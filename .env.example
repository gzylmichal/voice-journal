# Voice Journal — VPS Configuration
# Copy to .env and fill in your values

# ---------------------------------------------------------------------------
# Required: Groq (transcription via Whisper — always used)
# Get free key at https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# AI provider for journal formatting (auto = Claude > Gemini > Groq Llama)
# ---------------------------------------------------------------------------
AI_PROVIDER=auto

# Claude (Anthropic — paid, best quality)
ANTHROPIC_API_KEY=

# Gemini (Google AI Studio — free tier, very good)
GOOGLE_API_KEY=

# Groq Llama is the free fallback — no key needed beyond GROQ_API_KEY

# ---------------------------------------------------------------------------
# Notion (optional — leave blank to save .md files only)
# ---------------------------------------------------------------------------
NOTION_TOKEN=
NOTION_DATABASE_ID=          # journal daily entries DB
NOTION_WORKOUT_DB_ID=        # workout log DB (one row per exercise per session)
NOTION_TASK_DB_ID=           # tasks DB (extracted from voice memos)
NOTION_TRAINER_PAGE_ID=      # blank Notion page where weekly report is appended
NOTION_BODYWEIGHT_DB_ID=     # bodyweight log DB (one row per weigh-in)
NOTION_METRICS_DB_ID=        # daily metrics DB (sleep/energy; create with Date, Sleep select, Energy select, Note rich text, Name title)

# ---------------------------------------------------------------------------
# Upload authentication — shared secret with iOS Shortcut
# Generated automatically by setup.sh; change if compromised
# ---------------------------------------------------------------------------
UPLOAD_TOKEN=GENERATE_ME

# ---------------------------------------------------------------------------
# Transcription language
# "auto" = Whisper detects language per file (handles Polish + English mixed)
# "pl" = force Polish, "en" = force English
# ---------------------------------------------------------------------------
TRANSCRIPT_LANGUAGE=auto

# ---------------------------------------------------------------------------
# Paths — defaults match setup.sh layout, no need to change
# ---------------------------------------------------------------------------
BASE_DIR=/opt/voice-journal

# ---------------------------------------------------------------------------
# Google Calendar (optional — leave blank to skip)
# Run gcal_auth.py on your Mac first to generate gcal_token.json
# ---------------------------------------------------------------------------
# "primary" uses your main Google calendar. Or use a specific calendar ID from:
# calendar.google.com → Settings → your calendar → Calendar ID
GOOGLE_CALENDAR_ID=primary

# ---------------------------------------------------------------------------
# Morning Debrief + Weekly Review (debrief/)
# ---------------------------------------------------------------------------

# Location (for weather)
LATITUDE=50.0614
LONGITUDE=19.9366
TIMEZONE=Europe/Warsaw
LOCATION_NAME=Kraków

# SMTP — email delivery for debrief and weekly review
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Google Calendar service account JSON (separate from OAuth token above)
# A service account shared with your Google Calendar → read-only
GOOGLE_CREDENTIALS_FILE=/opt/voice-journal/debrief/service-account.json

# Binance (optional — leave blank to skip crypto prices)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Currency and news tuning (optional)
CURRENCY_CODES=USD,EUR,GBP,CHF
NEWS_GLOBAL_COUNT=7
NEWS_POLISH_COUNT=7

# ---------------------------------------------------------------------------
# Push notifications — ntfy.sh (optional)
# Pick a hard-to-guess topic name (it is the only auth on free ntfy.sh)
# e.g. vj-abc123xyz. Install the ntfy iOS app and subscribe to your topic.
# Leave blank to disable all push notifications.
# ---------------------------------------------------------------------------
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
